# bfdata 环境变量配置
# 复制为 .env 后填写实际值

# ===========================================
# 备份源配置
# ===========================================
# 备份源路径列表（JSON 数组格式，或逗号分隔）
# 支持环境变量展开: %TEMP%, %APPDATA%, %USERPROFILE% (Windows)
#                     $HOME, $TMPDIR (macOS/Linux)
BFDATA_SOURCES=["%TEMP%/vibe-kanban","%APPDATA%/bloop","D:/mydoc/vibekanban/.vibe-kanban-workspaces","%USERPROFILE%/.vibe-kanban","%USERPROFILE%/.claude","%USERPROFILE%/.claude.json","%USERPROFILE%/.claude-mem","D:/mydoc/k8s-uat","D:/mydoc/proxy","D:/mydoc/qianzhiji"]

# 备份输出目录
# 留空则输出到技能根目录的 backup/ 子目录
BFDATA_OUTPUT_DIR=

# 压缩工具: 7z / tar / auto (自动检测)
BFDATA_COMPRESS_CMD=auto

# ===========================================
# OSS 配置 (可选)
# ===========================================
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=

# OSS 存储路径前缀
BFDATA_OSS_KEY_PREFIX=bfdata

# ===========================================
# 清理策略
# ===========================================
# remove_on_upload_success: OSS 上传成功后删除本地归档
# keep_on_upload_fail: OSS 上传失败时保留本地归档（默认行为）
BFDATA_CLEANUP=keep_on_upload_fail
