# 备份配置模板
# 复制为 backup-config.json 后编辑
{
  "version": "1.0.0",
  "description": "bfdata 备份源配置",
  "sources": [
    {
      "name": "temp_workspace",
      "path": "${TEMP}/vibe-kanban",
      "required": false,
      "description": "临时工作区文件"
    },
    {
      "name": "bloop_config",
      "path": "${APPDATA}/bloop",
      "required": false,
      "description": "Bloop 数据库和配置"
    },
    {
      "name": "workspace_source",
      "path": "${BFDATA_WORKSPACE_DIR}",
      "required": true,
      "description": "工作区源代码"
    },
    {
      "name": "vibe_kanban",
      "path": "${USERPROFILE}/.vibe-kanban",
      "required": false,
      "description": "Vibe-Kanban 应用目录"
    },
    {
      "name": "claude_config",
      "path": "${USERPROFILE}/.claude",
      "required": false,
      "description": "Claude 配置目录"
    },
    {
      "name": "claude_json",
      "path": "${USERPROFILE}/.claude.json",
      "required": false,
      "description": "Claude 配置文件"
    },
    {
      "name": "claude_memory",
      "path": "${USERPROFILE}/.claude-mem",
      "required": false,
      "description": "Claude 记忆目录"
    }
  ],
  "compress_cmd": "auto",
  "oss": {
    "key_prefix": "bfdata",
    "cleanup_on_success": false
  }
}
